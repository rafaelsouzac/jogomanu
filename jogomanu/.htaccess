RewriteEngine On

# Impede o acesso direto a pastas sensíveis
RewriteRule ^(docs|model|controller) - [F,L]

# Condição: Se o que o usuário pediu NÃO for um diretório real
RewriteCond %{REQUEST_FILENAME} !-d
# Condição: Se o que o usuário pediu NÃO for um arquivo real (css, js, jpg)
RewriteCond %{REQUEST_FILENAME} !-f

# Regra: Mande tudo para o index.php, preservando a URL original no parâmetro 'url'
RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]